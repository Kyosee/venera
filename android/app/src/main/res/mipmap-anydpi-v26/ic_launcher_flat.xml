<?xml version="1.0" encoding="utf-8"?>
<!-- Full-bleed complete icon: foreground fills the canvas (no inset); the
     background color only shows where the launcher mask reveals edges. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
  <background android:drawable="@color/ic_launcher_flat_background"/>
  <foreground android:drawable="@mipmap/ic_launcher_flat_foreground"/>
</adaptive-icon>
